{
  "name": "@node9/policy-engine",
  "version": "1.0.0",
  "description": "Shared policy evaluation engine for node9 — DLP, smart rules, AST shell parsing, shields, loop detection. Pure functions, no I/O. Used by both node9-proxy and the node9 SaaS firewall.",
  "license": "Apache-2.0",
  "homepage": "https://node9.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node9-ai/node9-proxy.git",
    "directory": "packages/policy-engine"
  },
  "keywords": [
    "node9",
    "ai-security",
    "policy",
    "dlp",
    "agent-firewall"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "mvdan-sh": "^0.10.1",
    "picomatch": "^4.0.3",
    "safe-regex2": "^5.1.0"
  },
  "devDependencies": {
    "@types/picomatch": "^4.0.2",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
